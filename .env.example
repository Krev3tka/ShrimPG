# --- Server Configuration ---
SERVER_ADDRESS=127.0.0.1:8080
# Use 'http' or 'https'. If https, provide paths to certs.
SERVER_PROTOCOL=https
SSL_CERT_PATH=./server.crt
SSL_KEY_PATH=./server.key

# --- Database Configuration (PostgreSQL) ---
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://postgres:password@localhost:5432/shrimpg?sslmode=disable

# --- Redis Configuration ---
REDISDB_ADDRESS=127.0.0.1:6379
REDISDB_PASSWORD=
REDISDB_USER=
REDISDB_ID=0

# --- Security ---
# A fixed 32-byte string for session encryption (Base64 encoded)
# If empty, server will generate a new one on restart (killing old sessions)
SERVER_SECRET_KEY=
